# 阅微 AI 诊断系统 · 生产环境配置模板
# 复制此文件为 .env 并填写实际值

# ═══════════════════════════════════════════
#  DeepSeek API（必须设置）
# ═══════════════════════════════════════════
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ═══════════════════════════════════════════
#  JWT 密钥（必须设置）
#  推荐：openssl rand -base64 32
# ═══════════════════════════════════════════
JWT_SECRET=请使用随机字符串替换（推荐32位以上）

# ═══════════════════════════════════════════
#  服务器配置
# ═══════════════════════════════════════════
PORT=3002
HOST=0.0.0.0
NODE_ENV=production

# ═══════════════════════════════════════════
#  数据库路径
# ═══════════════════════════════════════════
DB_PATH=./data/yuewei.db
